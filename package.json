{
  "name": "labdocapp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron:dev": "concurrently \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && npx electron electron/main.js\"",
    "build:web": "expo export --platform web",
    "electron:build": "npm run build:web && electron-builder --win --config electron-builder.json",
    "dist": "npm run build:web && electron-builder --win --config electron-builder.json"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.6",
    "expo-auth-session": "~55.0.8",
    "expo-camera": "~55.0.9",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-image-picker": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.4"
  },
  "private": true
}
